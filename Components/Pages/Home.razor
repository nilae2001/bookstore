@page "/"
@implements IAsyncDisposable
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<BookstoreDb> DbFactory
@rendermode InteractiveServer

<PageTitle>Bookstore - Home</PageTitle>
<div class="row mt-5 mx-auto">
    <div class="col-sm-2 border pt-3 me-3 mb-3">
        <a href="/books/create" class="btn btn-primary">New Book</a>
        <div class="mt-3">
            <h6>Filter by:</h6>
            <select class="form-control" @bind="genreFilter">
                <option value="">Genre</option>
                @if (genres != null) {
                    @foreach(var genre in genres) {
                        <option value="@genre">@genre</option>
                    }
                }
            </select>
        </div>
        <div class="mt-3">
            <h6>Sort by:</h6>
            <select class="form-control" @bind="sortOrder">
                <option value="none">Price</option>
                <option value="low">Low Price</option>
                <option value="high">High Price</option>
            </select>
        </div>
    </div>
    <div class="col">
        @if (books is null) {
            <p>Loading...</p>
        } else {
            <div class="hstack flex-wrap gap-3">
                @foreach(var book in filtered) {
                    <BookCard Book="@book" />
                }
            </div>
        }
    </div>
</div>


@code {

    private BookstoreDb context { get; set; }

    private IEnumerable<Book> books => context.Books.AsNoTracking();

    private string genreFilter = string.Empty;

    private string sortOrder = "none";

    private IEnumerable<Book> filtered {
        get {
            var result = books.Where(b => string.IsNullOrWhiteSpace(genreFilter) || b.Genre == genreFilter);
            
            return sortOrder switch {
                "low" => result.OrderBy(b => b.Price),
                "high" => result.OrderByDescending(b => b.Price),
                _ => result
            };
        }
    }

    private IEnumerable<string> genres => books.Select(b => b.Genre).Distinct();

    protected override void OnInitialized(){
        context = DbFactory.CreateDbContext();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
