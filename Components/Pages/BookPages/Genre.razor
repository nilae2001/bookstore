@page "/genre/{GenreName}"
@using Microsoft.EntityFrameworkCore
@using Bookstore.Models
@inject IDbContextFactory<Bookstore.Data.BookstoreDb> DbFactory
@rendermode InteractiveServer

<PageTitle>Bookstore - Genre - @GenreName</PageTitle>

<h1 class="mt-4 mb-3">Genre: @GenreName</h1>

@if (books is null)
{
    <p>Loading...</p>
}
else if (!books.Any())
{
    <div class="alert alert-warning">No books found in this genre.</div>
}
else
{
    <div class="hstack flex-wrap gap-3">
        @foreach (var book in books)
        {
            <BookCard Book="@book" />
        }
    </div>
}

@code {
    [Parameter]
    public string GenreName { get; set; } = string.Empty;

    private List<Book> books = new();

    protected override async Task OnParametersSetAsync()
    {
        using var context = DbFactory.CreateDbContext();
        books = await context.Books
            .AsNoTracking()
            .Where(b => b.Genre == GenreName)
            .ToListAsync();
    }
}
